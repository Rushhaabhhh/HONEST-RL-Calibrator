# Python build/runtime
venv/
.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/

# Environment / secrets
.env
.env.local

# Test / lint cache
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Tooling caches
.claude/
.cursor/

# OS junk
.DS_Store

# Raw datasets are recreated by data/ingestion/* and excluded from git.
data/raw/*
!data/raw/.gitkeep

# Processed datasets ARE committed so the OpenEnv container is fully
# reproducible from a clean clone (no ingestion step required at build /
# runtime). Only ignore caches generated by ingestion scripts.
data/processed/.cache/

# Training artefacts (large checkpoints / wandb runs are local only)
honest-*-grpo/
wandb/
runs/
checkpoints/
*.bin
*.safetensors
adapter_*.bin

# Plot regeneration cache
docs/training/.cache/
